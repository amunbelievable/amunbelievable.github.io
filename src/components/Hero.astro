---
const bio =
  'Креативный лидер с 11+ годами опыта в разработке бренд-стратегий, 360-кампаний и web-продуктов. Наибольшая экспертиза - в iGaming и Affiliate. Этот лендинг-портфолио сделан методом вайб-кодинга и является демонстрацией моего опыта. Приятного просмотра!';
---
<section id="hero" class="hero">
  <div class="hero__bg" aria-hidden="true">
    <span class="hero__blob hero__blob--1"></span>
    <span class="hero__blob hero__blob--2"></span>
    <span class="hero__blob hero__blob--3"></span>
    <span class="hero__blob hero__blob--4"></span>
  </div>
  <div class="hero__card">
    <img class="hero__avatar" src="/hero/avatar.webp" alt="Антон Малаховский" width="168" height="168" />
    <h1 class="hero__name">Антон Малаховский</h1>
    <p class="hero__role">creative team lead</p>
    <p class="hero__tagline">digital | web | strategy</p>
    <p class="hero__bio">{bio}</p>
  </div>
</section>

<style>
  .hero { position: relative; min-height: 100svh; display: grid; place-items: center; text-align: center; overflow: hidden; scroll-snap-align: start; padding: var(--space); }
  .hero__bg {
    position: absolute; inset: 0; overflow: hidden;
    background: var(--aurora-bg);
    /* ── Параметры «живой авроры» (крути здесь) ── */
    --aurora-bg: #efe9f2;     /* база под пятнами */
    --aurora-c1: #7e7eff;     /* фиолетовый */
    --aurora-c2: #ffbf6d;     /* синий */
    --aurora-c3: #f02167;     /* розовый */
    --aurora-c4: #871080;     /* бирюза */
    --aurora-speed: 0.8;        /* множитель скорости: >1 медленнее, <1 быстрее */
    --aurora-blur: 60px;      /* мягкость пятен */
    --aurora-size: 59%;       /* размер пятна */
  }
  .hero__blob {
    position: absolute; width: var(--aurora-size); aspect-ratio: 1; border-radius: 50%;
    filter: blur(var(--aurora-blur)); will-change: transform;
    animation-timing-function: ease-in-out; animation-iteration-count: infinite;
  }
  /* Длительности взаимно простые (23/29/31/37с) — композиция пятен
     никогда визуально не зацикливается (органика без JS). */
  .hero__blob--1 { background: var(--aurora-c1); left: -8%;   top: -10%;    animation-name: aurora-1; animation-duration: calc(23s * var(--aurora-speed)); }
  .hero__blob--2 { background: var(--aurora-c2); right: -10%; top: -6%;     animation-name: aurora-2; animation-duration: calc(29s * var(--aurora-speed)); }
  .hero__blob--3 { background: var(--aurora-c3); right: -6%;  bottom: -14%; animation-name: aurora-3; animation-duration: calc(31s * var(--aurora-speed)); }
  .hero__blob--4 { background: var(--aurora-c4); left: -10%;  bottom: -10%; animation-name: aurora-4; animation-duration: calc(37s * var(--aurora-speed)); }

  /* Каждое пятно блуждает по своей кривой (не «маятник»). */
  @keyframes aurora-1 {
    0%,100% { transform: translate(0,0) scale(1); }
    25%     { transform: translate(22%, 12%) scale(1.1); }
    50%     { transform: translate(30%, 26%) scale(1.18); }
    75%     { transform: translate(10%, 20%) scale(1.07); }
  }
  @keyframes aurora-2 {
    0%,100% { transform: translate(0,0) scale(1); }
    25%     { transform: translate(-18%, 14%) scale(1.08); }
    50%     { transform: translate(-26%, 26%) scale(1.14); }
    75%     { transform: translate(-12%, 10%) scale(1.05); }
  }
  @keyframes aurora-3 {
    0%,100% { transform: translate(0,0) scale(1); }
    25%     { transform: translate(-14%, -16%) scale(1.1); }
    50%     { transform: translate(-24%, -26%) scale(1.2); }
    75%     { transform: translate(-8%, -12%) scale(1.06); }
  }
  @keyframes aurora-4 {
    0%,100% { transform: translate(0,0) scale(1); }
    25%     { transform: translate(16%, -12%) scale(1.07); }
    50%     { transform: translate(26%, -22%) scale(1.14); }
    75%     { transform: translate(12%, -8%) scale(1.05); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__blob { animation: none; }
  }
  .hero__card {
    position: relative; z-index: 1; width: 100%; max-width: 460px;
    background: rgba(255, 255, 255, .66);
    backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, .6); border-radius: 20px;
    padding: 40px 36px; box-shadow: 0 16px 50px rgba(0, 0, 0, .14);
  }
  .hero__avatar { width: 168px; height: 168px; border-radius: 50%; object-fit: cover; margin: 0 auto 22px; border: 4px solid rgba(255, 255, 255, .9); box-shadow: 0 8px 24px rgba(0, 0, 0, .18); }
  .hero__name { font-size: clamp(28px, 6vw, 44px); font-weight: 600; letter-spacing: .5px; }
  .hero__role { margin-top: 8px; font-size: 13px; letter-spacing: 3px; text-transform: uppercase; color: var(--fg); }
  .hero__tagline { margin-top: 4px; font-size: 12px; letter-spacing: 2px; color: var(--muted); }
  .hero__bio { margin-top: 18px; font-size: 14px; line-height: 1.7; color: var(--fg); }
  @media (max-width: 768px) {
    .hero__card { padding: 32px 24px; }
    .hero__avatar { width: 132px; height: 132px; }
  }
</style>

<script>
  // Optional polish: randomise each blob's phase + nudge its speed so the
  // aurora looks different on every visit and never settles into a visible
  // loop. Pure progressive enhancement — without JS the CSS already animates;
  // skipped entirely when the user prefers reduced motion.
  function initAurora() {
    const bg = document.querySelector('.hero__bg');
    if (!bg) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    bg.querySelectorAll<HTMLElement>('.hero__blob').forEach((b) => {
      const base = parseFloat(getComputedStyle(b).animationDuration) || 24; // honours --aurora-speed
      const dur = base * (0.85 + Math.random() * 0.3);                      // ±15% jitter
      b.style.animationDuration = `${dur.toFixed(2)}s`;
      b.style.animationDelay = `-${(Math.random() * dur).toFixed(2)}s`;     // random starting phase
    });
  }
  document.addEventListener('astro:page-load', initAurora);
</script>
