---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import ContactsPopup from '../components/ContactsPopup.astro';
import '../styles/global.css';

interface Props { title?: string; description?: string; }
const {
  title = 'Anton Malakhovskiy',
  description = 'Senior Creator & Brand Manager portfolio',
} = Astro.props;

// Absolute URL for OG image (falls back gracefully if site is unset)
const ogImage = Astro.site ? new URL('/favicon.png', Astro.site).href : '/favicon.png';
const pageUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={pageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
  </head>
  <body>
    <Header />
    <ContactsPopup />
    <slot />
  </body>
</html>
