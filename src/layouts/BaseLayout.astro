---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import ContactsPopup from '../components/ContactsPopup.astro';
import '../styles/global.css';

interface Props { title?: string; description?: string; }
const {
  title = 'Anton Malakhovskiy',
  description = 'Senior Creator & Brand Manager portfolio',
} = Astro.props;

// Absolute URL for OG image (falls back gracefully if site is unset)
const ogImage = Astro.site ? new URL('/favicon.png', Astro.site).href : '/favicon.png';
const pageUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Take over scroll restoration BEFORE the browser restores a saved
         position. Without this, a reload restores the previous (footer)
         scroll position before any other script runs. Inline + early so it
         wins the race; ClientRouter also relies on manual restoration. -->
    <script is:inline>history.scrollRestoration = 'manual';</script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={pageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <ClientRouter />
  </head>
  <body>
    <Header />
    <ContactsPopup />
    <slot />
    <script>
      // A forward SPA navigation to a fresh page must open at the top.
      // ClientRouter's own scroll reset is suppressed by
      // history.scrollRestoration='manual' (set above for the home preloader),
      // so without this a case detail page inherits the home page's scroll
      // position and opens scrolled down. Reset explicitly — but skip the two
      // cases the preloader already positions: the home #hero page, and a
      // "#case-…" return-to-case navigation.
      function resetScrollOnSwap() {
        if (location.hash.startsWith('#case-')) return;
        if (document.getElementById('hero')) return;
        // Jump (not smooth) and override scroll-behavior so the global
        // `scroll-behavior: smooth` doesn't animate — and so a late
        // ClientRouter scroll restore can't win over us.
        const root = document.documentElement;
        const prev = root.style.scrollBehavior;
        root.style.scrollBehavior = 'auto';
        window.scrollTo(0, 0);
        root.style.scrollBehavior = prev;
      }
      // after-swap = before paint (no flash); page-load = after ClientRouter's
      // own scroll handling (wins if after-swap fired too early).
      document.addEventListener('astro:after-swap', resetScrollOnSwap);
      document.addEventListener('astro:page-load', resetScrollOnSwap);
    </script>
  </body>
</html>
