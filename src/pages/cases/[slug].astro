---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { resolveCaseColors } from '../../lib/colors';
import { renderRichText } from '../../lib/richtext';

export async function getStaticPaths() {
  const cases = await getCollection('cases');
  return cases.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { title, years, heading, slides } = entry.data;
const ordered = [...slides].sort((a, b) => a.order - b.order);
const multi = ordered.length > 1;
const colors = resolveCaseColors(entry.data.bg, entry.data.fg);
---
<BaseLayout title={`${title} — Антон Малаховский`}>
  <div class="detail-page" style={`--case-bg:${colors.bg};--case-fg:${colors.fg};`}>
  <article class="detail" data-carousel>
    <div class="detail__head">
      <h1 class="detail__title">{title}</h1>
      <p class="detail__years">{years}</p>
    </div>

    <div class="detail__left">
      <div class="banner">
        <div class="banner__track" data-track>
          {ordered.map((s, i) => (
            <div class:list={['banner__slide', { 'is-active': i === 0 }]} data-slide={i}>
              {s.type === 'video' ? (
                <video data-video src={s.src} loop muted playsinline preload="metadata"></video>
              ) : (
                <img src={s.src} alt={`${title} — ${i + 1}`} />
              )}
            </div>
          ))}
        </div>
        {multi && (
          <button class="banner__nav banner__nav--prev" data-prev type="button" aria-label="Предыдущий слайд">‹</button>
        )}
        {multi && (
          <button class="banner__nav banner__nav--next" data-next type="button" aria-label="Следующий слайд">›</button>
        )}
      </div>
      {multi && (
        <div class="dots" aria-label="Навигация по слайдам">
          {ordered.map((s, i) => (
            <button class:list={['dot', { 'is-active': i === 0 }]} data-dot={i} type="button" aria-label={`Слайд ${i + 1}`}></button>
          ))}
        </div>
      )}
    </div>

    <div class="detail__body">
      <h2 class="detail__heading">{heading}</h2>
      <div class="detail__texts">
        {ordered.map((s, i) => (
          <div class:list={['detail__text', { 'is-active': i === 0 }]} data-text={i} set:html={renderRichText(s.text ?? '')} />
        ))}
      </div>
      <a class="detail__back" href={`/#case-${entry.id}`} data-back={entry.id}>← Назад</a>
    </div>
  </article>
  </div>
</BaseLayout>

<style>
  .detail-page {
    min-height: 100vh;
    background: var(--case-bg, #fff); color: var(--case-fg, #111);
    transition: background-color .3s ease, color .3s ease;
  }
  .detail {
    display: grid; grid-template-columns: 1fr 1fr;
    grid-template-areas: "media head" "media body";
    gap: 12px var(--space); max-width: var(--maxw); margin: 0 auto;
    padding: 28px var(--space) var(--space); align-items: start;
  }
  .detail__head { grid-area: head; }
  .detail__left { grid-area: media; position: sticky; top: 80px; }
  .detail__body { grid-area: body; }

  .banner {
    position: relative; width: 100%; max-width: 440px; margin: 0 auto;
    aspect-ratio: 16 / 25; max-height: 78vh;
    border-radius: 10px; overflow: hidden;
    background: color-mix(in srgb, var(--case-fg, #111) 8%, transparent);
    /* JS owns horizontal swipe; let vertical page scroll pass through. */
    touch-action: pan-y;
  }
  .banner__track { display: flex; width: 100%; height: 100%; transition: transform .4s ease; will-change: transform; }
  .banner__slide { flex: 0 0 100%; width: 100%; height: 100%; display: grid; place-items: center; }
  .banner__slide img, .banner__slide video { width: 100%; height: 100%; object-fit: cover; }

  .banner__nav {
    position: absolute; top: 50%; transform: translateY(-50%);
    width: 48px; height: 48px; border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, .45);
    background: rgba(0, 0, 0, .5);
    -webkit-backdrop-filter: blur(6px); backdrop-filter: blur(6px);
    color: #fff; font-size: 24px; line-height: 1; cursor: pointer; z-index: 2;
    display: grid; place-items: center;
    box-shadow: 0 4px 14px rgba(0, 0, 0, .25);
    transition: background .2s ease;
  }
  .banner__nav:hover { background: rgba(0, 0, 0, .72); }
  .banner__nav--prev { left: 12px; }
  .banner__nav--next { right: 12px; }

  .dots { display: flex; justify-content: center; gap: 10px; margin-top: 16px; }
  .dot { width: 9px; height: 9px; padding: 0; border-radius: 50%; border: 1px solid var(--case-fg, #111); background: transparent; cursor: pointer; transition: background .2s ease; }
  .dot.is-active { background: var(--case-fg, #111); }

  .detail__title { font-size: clamp(28px, 4vw, 44px); font-weight: 600; }
  .detail__years { color: var(--case-fg, #111); opacity: .6; letter-spacing: 1px; margin-top: 6px; }
  .detail__heading { font-size: 18px; font-weight: 500; color: var(--case-fg, #111); opacity: .65; margin-top: 8px; }
  .detail__texts { margin-top: 28px; }
  .detail__text { display: none; white-space: pre-line; line-height: 1.75; }
  .detail__text.is-active { display: block; }
  .detail__back { display: inline-block; margin-top: 40px; border: 1px solid var(--case-fg, #111); border-radius: 999px; padding: 10px 24px; font-size: 13px; }
  .detail__back:hover { background: var(--case-fg, #111); color: var(--case-bg, #fff); }

  @media (max-width: 768px) {
    .detail { grid-template-columns: 1fr; grid-template-areas: "head" "media" "body"; padding-top: 16px; }
    .detail__left { position: static; }
    /* Shrink the banner ~10% (aspect-ratio preserved) so the now-present sticky header doesn't crop it. */
    .banner { width: 90%; }
    /* Halved arrows on mobile. */
    .banner__nav { width: 24px; height: 24px; font-size: 15px; }
    .banner__nav--prev { left: 8px; }
    .banner__nav--next { right: 8px; }
  }
  @media (prefers-reduced-motion: reduce) {
    .banner__track { transition: none; }
  }
</style>

<script>
  function initCarousel() {
    const root = document.querySelector('[data-carousel]');
    if (!root) return;
    const track = root.querySelector('[data-track]') as HTMLElement | null;
    const banner = root.querySelector('.banner') as HTMLElement | null;
    const slides = Array.from(root.querySelectorAll('.banner__slide'));
    const texts = Array.from(root.querySelectorAll('.detail__text'));
    const dots = Array.from(root.querySelectorAll('[data-dot]'));
    const total = slides.length;
    if (!track || !total) return;

    let idx = 0;

    function paint() {
      slides.forEach((s, i) => {
        const active = i === idx;
        s.classList.toggle('is-active', active);
        const v = s.querySelector('video') as HTMLVideoElement | null;
        if (v) {
          if (active) { v.muted = true; v.play().catch(() => {}); }
          else { v.pause(); try { v.currentTime = 0; } catch {} }
        }
      });
      texts.forEach((t, i) => t.classList.toggle('is-active', i === idx));
      dots.forEach((d, i) => {
        const active = i === idx;
        d.classList.toggle('is-active', active);
        d.setAttribute('aria-current', active ? 'true' : 'false');
      });
    }
    function go(n: number) {
      idx = ((n % total) + total) % total;
      track!.style.transition = '';
      track!.style.transform = `translateX(${-idx * 100}%)`;
      paint();
    }

    root.querySelector('[data-prev]')?.addEventListener('click', () => go(idx - 1));
    root.querySelector('[data-next]')?.addEventListener('click', () => go(idx + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => go(i)));

    // Finger-following swipe (mobile): the track tracks the finger, then snaps.
    let startX = 0, startY = 0, dragging = false, decided = false, horiz = false, width = 1;
    banner?.addEventListener('touchstart', (e) => {
      const t = (e as TouchEvent).touches[0];
      startX = t.clientX; startY = t.clientY;
      dragging = true; decided = false; horiz = false;
      width = banner.clientWidth || 1;
    }, { passive: true });
    banner?.addEventListener('touchmove', (e) => {
      if (!dragging) return;
      const t = (e as TouchEvent).touches[0];
      const dx = t.clientX - startX;
      const dy = t.clientY - startY;
      if (!decided) {
        if (Math.abs(dx) > 8 || Math.abs(dy) > 8) {
          decided = true;
          horiz = Math.abs(dx) > Math.abs(dy);
          if (horiz) track!.style.transition = 'none';
          else dragging = false; // vertical scroll — don't hijack
        }
      }
      if (horiz) {
        e.preventDefault(); // own the horizontal gesture (non-passive)
        const pct = (dx / width) * 100;
        track!.style.transform = `translateX(${-idx * 100 + pct}%)`;
      }
    }, { passive: false });
    banner?.addEventListener('touchend', (e) => {
      if (!dragging || !horiz) { dragging = false; return; }
      dragging = false;
      const dx = (e as TouchEvent).changedTouches[0].clientX - startX;
      track!.style.transition = '';
      if (Math.abs(dx) > width * 0.2) { go(dx < 0 ? idx + 1 : idx - 1); }
      else { track!.style.transform = `translateX(${-idx * 100}%)`; } // snap back
    }, { passive: true });

    // Initial position without animation.
    track.style.transition = 'none';
    track.style.transform = 'translateX(0%)';
    paint();
    requestAnimationFrame(() => { if (track) track.style.transition = ''; });
  }

  document.addEventListener('astro:page-load', initCarousel);
</script>
